.floating-cart-area{position:fixed;top:0;left:0;width:100%;height:100%;z-index:9999;pointer-events:none}.floating-cart-btn--movable{pointer-events:auto}.floating-cart-btn__inner{width:100%;height:100%;display:flex;align-items:center;justify-content:center;box-sizing:border-box;padding:24rpx;background-color:#fff;border-radius:50%;box-shadow:0 2rpx 8rpx rgba(0,0,0,.2);position:relative;overflow:visible}.floating-cart-btn{display:flex;align-items:center;justify-content:center;box-sizing:border-box;background-color:#fff;border-radius:50%;box-shadow:0 2rpx 8rpx rgba(0,0,0,.2);overflow:visible;touch-action:none}.floating-cart-btn__icon{width:52rpx;height:52rpx;pointer-events:none}.floating-cart-btn__badge{position:absolute;top:4rpx;right:4rpx;min-width:32rpx;height:32rpx;padding:0 8rpx;box-sizing:border-box;background-color:red;border-radius:999rpx;display:flex;align-items:center;justify-content:center;pointer-events:none}.floating-cart-btn__badge-text{color:#fff;font-size:22rpx;font-weight:500;line-height:28rpx}
